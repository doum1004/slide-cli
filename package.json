{
  "name": "slide-cli",
  "version": "1.0.0",
  "description": "CLI to create beautiful slide cards (9:16) from JSON + templates",
  "module": "index.ts",
  "type": "module",
  "bin": { "slide": "./src/index.ts" },
  "scripts": {
    "postinstall": "node scripts/download-fonts.js",
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts"
  },
  "private": true,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/outfit": "^5.2.8",
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/lato": "^5.2.7",
    "@fontsource/playfair-display": "^5.2.8",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "handlebars": "^4.7.8",
    "ora": "^9.3.0",
    "puppeteer": "^24.40.0",
    "zod": "^4.3.6"
  }
}
