{
  "name": "Data Layouts",
  "id": "data-layouts-wide",
  "version": "1.0.0",
  "description": "Multi-layout data visualization template for 16:9 presentations — supports text, bar charts, horizontal bar charts, tables, flow diagrams, stat grids, comparison columns, timelines, and funnel diagrams. Every layout supports an optional image. All rendered with pure CSS and Handlebars, no JavaScript.",
  "author": "slide-cli",
  "aspectRatio": "16:9",
  "width": 1920,
  "height": 1080,
  "slots": [
    { "id": "heading",      "type": "text",  "label": "Heading",          "required": true,  "description": "Slide heading. 2–8 words. Displayed at ~56px." },
    { "id": "subheading",   "type": "text",  "label": "Subheading",       "required": false, "default": "", "description": "Optional context line below heading. 1 sentence." },
    { "id": "label",        "type": "text",  "label": "Eyebrow label",    "required": false, "default": "", "description": "Uppercase eyebrow tag above heading (e.g. 'Q4 RESULTS')." },
    { "id": "footnote",     "type": "text",  "label": "Footnote",         "required": false, "default": "", "description": "Small footnote at bottom left (e.g. 'Source: internal data')." },

    { "id": "image",         "type": "image", "label": "Slide image",      "required": false, "default": "", "description": "Optional image for any layout. Renders as a right-side panel (text, stat-grid, table, bar-chart, hbar, comparison) or top-right inset (flow, timeline, funnel). Leave empty for full-width data layout." },
    { "id": "image-caption", "type": "text",  "label": "Image caption",    "required": false, "default": "", "description": "Optional small caption below the image." },

    { "id": "body",          "type": "text",  "label": "Body text",        "required": false, "default": "", "description": "Body paragraph for text layout. 1–5 sentences. Presence of body WITHOUT any data slots activates the text layout." },
    { "id": "body-2",        "type": "text",  "label": "Body paragraph 2", "required": false, "default": "", "description": "Optional second paragraph for text layout." },
    { "id": "bullet-1",      "type": "text",  "label": "Bullet 1",        "required": false, "default": "", "description": "First bullet point for text layout. Short — 1 line." },
    { "id": "bullet-2",      "type": "text",  "label": "Bullet 2",        "required": false, "default": "", "description": "Second bullet point." },
    { "id": "bullet-3",      "type": "text",  "label": "Bullet 3",        "required": false, "default": "", "description": "Third bullet point." },
    { "id": "bullet-4",      "type": "text",  "label": "Bullet 4",        "required": false, "default": "", "description": "Fourth bullet point." },
    { "id": "bullet-5",      "type": "text",  "label": "Bullet 5",        "required": false, "default": "", "description": "Fifth bullet point." },
    { "id": "bullet-6",      "type": "text",  "label": "Bullet 6",        "required": false, "default": "", "description": "Sixth bullet point." },
    { "id": "callout",       "type": "text",  "label": "Callout",         "required": false, "default": "", "description": "Optional highlighted callout box text for text layout." },

    { "id": "bar-label-1",   "type": "text",   "label": "Bar 1 label",    "required": false, "default": "", "description": "X-axis label for bar 1. Presence activates bar chart." },
    { "id": "bar-value-1",   "type": "number", "label": "Bar 1 height %", "required": false, "default": 0,  "description": "Bar 1 height as percentage 0–100." },
    { "id": "bar-display-1", "type": "text",   "label": "Bar 1 display",  "required": false, "default": "", "description": "Display text above bar 1 (e.g. '$1.2M')." },
    { "id": "bar-label-2",   "type": "text",   "label": "Bar 2 label",    "required": false, "default": "" },
    { "id": "bar-value-2",   "type": "number", "label": "Bar 2 height %", "required": false, "default": 0 },
    { "id": "bar-display-2", "type": "text",   "label": "Bar 2 display",  "required": false, "default": "" },
    { "id": "bar-label-3",   "type": "text",   "label": "Bar 3 label",    "required": false, "default": "" },
    { "id": "bar-value-3",   "type": "number", "label": "Bar 3 height %", "required": false, "default": 0 },
    { "id": "bar-display-3", "type": "text",   "label": "Bar 3 display",  "required": false, "default": "" },
    { "id": "bar-label-4",   "type": "text",   "label": "Bar 4 label",    "required": false, "default": "" },
    { "id": "bar-value-4",   "type": "number", "label": "Bar 4 height %", "required": false, "default": 0 },
    { "id": "bar-display-4", "type": "text",   "label": "Bar 4 display",  "required": false, "default": "" },
    { "id": "bar-label-5",   "type": "text",   "label": "Bar 5 label",    "required": false, "default": "" },
    { "id": "bar-value-5",   "type": "number", "label": "Bar 5 height %", "required": false, "default": 0 },
    { "id": "bar-display-5", "type": "text",   "label": "Bar 5 display",  "required": false, "default": "" },
    { "id": "bar-label-6",   "type": "text",   "label": "Bar 6 label",    "required": false, "default": "" },
    { "id": "bar-value-6",   "type": "number", "label": "Bar 6 height %", "required": false, "default": 0 },
    { "id": "bar-display-6", "type": "text",   "label": "Bar 6 display",  "required": false, "default": "" },
    { "id": "bar-label-7",   "type": "text",   "label": "Bar 7 label",    "required": false, "default": "" },
    { "id": "bar-value-7",   "type": "number", "label": "Bar 7 height %", "required": false, "default": 0 },
    { "id": "bar-display-7", "type": "text",   "label": "Bar 7 display",  "required": false, "default": "" },
    { "id": "bar-label-8",   "type": "text",   "label": "Bar 8 label",    "required": false, "default": "" },
    { "id": "bar-value-8",   "type": "number", "label": "Bar 8 height %", "required": false, "default": 0 },
    { "id": "bar-display-8", "type": "text",   "label": "Bar 8 display",  "required": false, "default": "" },

    { "id": "hbar-label-1",   "type": "text",   "label": "H-Bar 1 label",   "required": false, "default": "", "description": "Label for horizontal bar 1. Presence activates horizontal bar chart." },
    { "id": "hbar-value-1",   "type": "number", "label": "H-Bar 1 width %", "required": false, "default": 0 },
    { "id": "hbar-display-1", "type": "text",   "label": "H-Bar 1 display", "required": false, "default": "" },
    { "id": "hbar-label-2",   "type": "text",   "label": "H-Bar 2 label",   "required": false, "default": "" },
    { "id": "hbar-value-2",   "type": "number", "label": "H-Bar 2 width %", "required": false, "default": 0 },
    { "id": "hbar-display-2", "type": "text",   "label": "H-Bar 2 display", "required": false, "default": "" },
    { "id": "hbar-label-3",   "type": "text",   "label": "H-Bar 3 label",   "required": false, "default": "" },
    { "id": "hbar-value-3",   "type": "number", "label": "H-Bar 3 width %", "required": false, "default": 0 },
    { "id": "hbar-display-3", "type": "text",   "label": "H-Bar 3 display", "required": false, "default": "" },
    { "id": "hbar-label-4",   "type": "text",   "label": "H-Bar 4 label",   "required": false, "default": "" },
    { "id": "hbar-value-4",   "type": "number", "label": "H-Bar 4 width %", "required": false, "default": 0 },
    { "id": "hbar-display-4", "type": "text",   "label": "H-Bar 4 display", "required": false, "default": "" },
    { "id": "hbar-label-5",   "type": "text",   "label": "H-Bar 5 label",   "required": false, "default": "" },
    { "id": "hbar-value-5",   "type": "number", "label": "H-Bar 5 width %", "required": false, "default": 0 },
    { "id": "hbar-display-5", "type": "text",   "label": "H-Bar 5 display", "required": false, "default": "" },
    { "id": "hbar-label-6",   "type": "text",   "label": "H-Bar 6 label",   "required": false, "default": "" },
    { "id": "hbar-value-6",   "type": "number", "label": "H-Bar 6 width %", "required": false, "default": 0 },
    { "id": "hbar-display-6", "type": "text",   "label": "H-Bar 6 display", "required": false, "default": "" },

    { "id": "table-h-1",   "type": "text", "label": "Table header 1", "required": false, "default": "", "description": "First column header. Presence activates table layout." },
    { "id": "table-h-2",   "type": "text", "label": "Table header 2", "required": false, "default": "" },
    { "id": "table-h-3",   "type": "text", "label": "Table header 3", "required": false, "default": "" },
    { "id": "table-h-4",   "type": "text", "label": "Table header 4", "required": false, "default": "" },
    { "id": "table-h-5",   "type": "text", "label": "Table header 5", "required": false, "default": "" },
    { "id": "table-r1-c1", "type": "text", "label": "Row 1 Col 1",   "required": false, "default": "" },
    { "id": "table-r1-c2", "type": "text", "label": "Row 1 Col 2",   "required": false, "default": "" },
    { "id": "table-r1-c3", "type": "text", "label": "Row 1 Col 3",   "required": false, "default": "" },
    { "id": "table-r1-c4", "type": "text", "label": "Row 1 Col 4",   "required": false, "default": "" },
    { "id": "table-r1-c5", "type": "text", "label": "Row 1 Col 5",   "required": false, "default": "" },
    { "id": "table-r2-c1", "type": "text", "label": "Row 2 Col 1",   "required": false, "default": "" },
    { "id": "table-r2-c2", "type": "text", "label": "Row 2 Col 2",   "required": false, "default": "" },
    { "id": "table-r2-c3", "type": "text", "label": "Row 2 Col 3",   "required": false, "default": "" },
    { "id": "table-r2-c4", "type": "text", "label": "Row 2 Col 4",   "required": false, "default": "" },
    { "id": "table-r2-c5", "type": "text", "label": "Row 2 Col 5",   "required": false, "default": "" },
    { "id": "table-r3-c1", "type": "text", "label": "Row 3 Col 1",   "required": false, "default": "" },
    { "id": "table-r3-c2", "type": "text", "label": "Row 3 Col 2",   "required": false, "default": "" },
    { "id": "table-r3-c3", "type": "text", "label": "Row 3 Col 3",   "required": false, "default": "" },
    { "id": "table-r3-c4", "type": "text", "label": "Row 3 Col 4",   "required": false, "default": "" },
    { "id": "table-r3-c5", "type": "text", "label": "Row 3 Col 5",   "required": false, "default": "" },
    { "id": "table-r4-c1", "type": "text", "label": "Row 4 Col 1",   "required": false, "default": "" },
    { "id": "table-r4-c2", "type": "text", "label": "Row 4 Col 2",   "required": false, "default": "" },
    { "id": "table-r4-c3", "type": "text", "label": "Row 4 Col 3",   "required": false, "default": "" },
    { "id": "table-r4-c4", "type": "text", "label": "Row 4 Col 4",   "required": false, "default": "" },
    { "id": "table-r4-c5", "type": "text", "label": "Row 4 Col 5",   "required": false, "default": "" },
    { "id": "table-r5-c1", "type": "text", "label": "Row 5 Col 1",   "required": false, "default": "" },
    { "id": "table-r5-c2", "type": "text", "label": "Row 5 Col 2",   "required": false, "default": "" },
    { "id": "table-r5-c3", "type": "text", "label": "Row 5 Col 3",   "required": false, "default": "" },
    { "id": "table-r5-c4", "type": "text", "label": "Row 5 Col 4",   "required": false, "default": "" },
    { "id": "table-r5-c5", "type": "text", "label": "Row 5 Col 5",   "required": false, "default": "" },

    { "id": "flow-step-1", "type": "text", "label": "Flow step 1", "required": false, "default": "", "description": "First step label. Presence activates flow layout." },
    { "id": "flow-desc-1", "type": "text", "label": "Flow desc 1", "required": false, "default": "" },
    { "id": "flow-step-2", "type": "text", "label": "Flow step 2", "required": false, "default": "" },
    { "id": "flow-desc-2", "type": "text", "label": "Flow desc 2", "required": false, "default": "" },
    { "id": "flow-step-3", "type": "text", "label": "Flow step 3", "required": false, "default": "" },
    { "id": "flow-desc-3", "type": "text", "label": "Flow desc 3", "required": false, "default": "" },
    { "id": "flow-step-4", "type": "text", "label": "Flow step 4", "required": false, "default": "" },
    { "id": "flow-desc-4", "type": "text", "label": "Flow desc 4", "required": false, "default": "" },
    { "id": "flow-step-5", "type": "text", "label": "Flow step 5", "required": false, "default": "" },
    { "id": "flow-desc-5", "type": "text", "label": "Flow desc 5", "required": false, "default": "" },

    { "id": "stat-value-1", "type": "text", "label": "Stat value 1", "required": false, "default": "", "description": "Large stat number. Presence activates stat grid." },
    { "id": "stat-label-1", "type": "text", "label": "Stat label 1", "required": false, "default": "" },
    { "id": "stat-value-2", "type": "text", "label": "Stat value 2", "required": false, "default": "" },
    { "id": "stat-label-2", "type": "text", "label": "Stat label 2", "required": false, "default": "" },
    { "id": "stat-value-3", "type": "text", "label": "Stat value 3", "required": false, "default": "" },
    { "id": "stat-label-3", "type": "text", "label": "Stat label 3", "required": false, "default": "" },
    { "id": "stat-value-4", "type": "text", "label": "Stat value 4", "required": false, "default": "" },
    { "id": "stat-label-4", "type": "text", "label": "Stat label 4", "required": false, "default": "" },

    { "id": "compare-left-title",  "type": "text", "label": "Left column title",  "required": false, "default": "", "description": "Presence activates comparison layout." },
    { "id": "compare-right-title", "type": "text", "label": "Right column title", "required": false, "default": "" },
    { "id": "compare-left-1",  "type": "text", "label": "Left item 1",  "required": false, "default": "" },
    { "id": "compare-left-2",  "type": "text", "label": "Left item 2",  "required": false, "default": "" },
    { "id": "compare-left-3",  "type": "text", "label": "Left item 3",  "required": false, "default": "" },
    { "id": "compare-left-4",  "type": "text", "label": "Left item 4",  "required": false, "default": "" },
    { "id": "compare-right-1", "type": "text", "label": "Right item 1", "required": false, "default": "" },
    { "id": "compare-right-2", "type": "text", "label": "Right item 2", "required": false, "default": "" },
    { "id": "compare-right-3", "type": "text", "label": "Right item 3", "required": false, "default": "" },
    { "id": "compare-right-4", "type": "text", "label": "Right item 4", "required": false, "default": "" },

    { "id": "timeline-date-1",  "type": "text", "label": "Timeline date 1",  "required": false, "default": "", "description": "Presence activates timeline." },
    { "id": "timeline-event-1", "type": "text", "label": "Timeline event 1", "required": false, "default": "" },
    { "id": "timeline-date-2",  "type": "text", "label": "Timeline date 2",  "required": false, "default": "" },
    { "id": "timeline-event-2", "type": "text", "label": "Timeline event 2", "required": false, "default": "" },
    { "id": "timeline-date-3",  "type": "text", "label": "Timeline date 3",  "required": false, "default": "" },
    { "id": "timeline-event-3", "type": "text", "label": "Timeline event 3", "required": false, "default": "" },
    { "id": "timeline-date-4",  "type": "text", "label": "Timeline date 4",  "required": false, "default": "" },
    { "id": "timeline-event-4", "type": "text", "label": "Timeline event 4", "required": false, "default": "" },
    { "id": "timeline-date-5",  "type": "text", "label": "Timeline date 5",  "required": false, "default": "" },
    { "id": "timeline-event-5", "type": "text", "label": "Timeline event 5", "required": false, "default": "" },

    { "id": "funnel-stage-1", "type": "text", "label": "Funnel stage 1", "required": false, "default": "", "description": "Widest stage. Presence activates funnel." },
    { "id": "funnel-value-1", "type": "text", "label": "Funnel value 1", "required": false, "default": "" },
    { "id": "funnel-stage-2", "type": "text", "label": "Funnel stage 2", "required": false, "default": "" },
    { "id": "funnel-value-2", "type": "text", "label": "Funnel value 2", "required": false, "default": "" },
    { "id": "funnel-stage-3", "type": "text", "label": "Funnel stage 3", "required": false, "default": "" },
    { "id": "funnel-value-3", "type": "text", "label": "Funnel value 3", "required": false, "default": "" },
    { "id": "funnel-stage-4", "type": "text", "label": "Funnel stage 4", "required": false, "default": "" },
    { "id": "funnel-value-4", "type": "text", "label": "Funnel value 4", "required": false, "default": "" },
    { "id": "funnel-stage-5", "type": "text", "label": "Funnel stage 5", "required": false, "default": "" },
    { "id": "funnel-value-5", "type": "text", "label": "Funnel value 5", "required": false, "default": "" },

    { "id": "bg",               "type": "color", "label": "Background",       "required": false, "default": "#0f0e0c", "description": "Background color. Keep consistent across all slides." },
    { "id": "ink",              "type": "color", "label": "Text color",       "required": false, "default": "#f0ece4", "description": "Primary text color. Keep consistent across all slides." },
    { "id": "accent",           "type": "color", "label": "Accent color",     "required": false, "default": "#e8b86d", "description": "Accent for bars, highlights, active elements. Vary per slide." },
    { "id": "accent-secondary", "type": "color", "label": "Secondary accent", "required": false, "default": "", "description": "Optional second accent for comparison right column. If empty, accent is used." }
  ]
}
